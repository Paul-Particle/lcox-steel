# Gitignore for cfp_data_analysis project

# Operating System Files
.DS_Store
.ipynb_checkpoints/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
*.env
.env

# Data files
*.feather
*.CSV
entsoe_cache/
integrated/

# Log files
logs/

# Snakemake
.snakemake/
.snakemake_profile/
.snakemake_log/

# Generated results
results/*.html
results/*.png
results/*.svg
results/*.json

# IDE specific files
.vscode/
*.swp
output_for_gemini
.antigravitycli
.claude

# Conda environment
fca_env/

# Git attributes
* text=auto eol=lf

# Atlite / ERA5
data/cutouts/
*.nc

# Raw/large geodata (download manually — see README)
data/shapes/eez/
data/shapes/ne_110m_admin_0_countries/
data/shapes/*.zip

# Derived shape files are committed (small, reproducible outputs)
# data/shapes/regions.geojson and offshore_regions.geojson are tracked

# Debug artefacts
data/debug/
# Local virtualenv (Atlite)
.venv-atlite/

# Local temporary data
data/tmp/

# Model outputs
results/
results.zip