configfile: "config/config.yaml"


import pandas as pd

projects_df = pd.read_csv(
    "config/projects.csv", dtype={"start_date": str, "end_date": str}
)


include: "rules/common.smk"
include: "rules/grid.smk"
include: "rules/res_cf.smk"
include: "rules/h2_dri.smk"


rule all:
    default_target: True
    input:
        # One report per project.
        expand(
            "results/report_{project}.csv",
            project=projects_df["project"].unique().tolist(),
        ),
        # Full per-zone ENTSO-E dataset (non-price metrics) — a top-level target
        # for now until something downstream consumes it.
        collect(
            "resources/{item.pipeline}/{item.area}_{item.tech}_{item.variant}_{item.start_date}_{item.end_date}_full.parquet",
            item=lookup(query="tech == 'grid'", within=projects_df),
        ),
