configfile: "config/config.yaml"

import yaml
with open("config/projects.yaml") as _f:
    projects = yaml.safe_load(_f)


include: "rules/common.smk"
include: "rules/grid.smk"
include: "rules/res_cf.smk"
include: "rules/h2_dri.smk"


rule all:
    default_target: True
    input:
        expand(
            "results/report_{project}.csv",
            project=lookup(dpath="projects", within=projects),
        ),
        # Full per-zone ENTSO-E dataset (non-price metrics) — a top-level target
        # for now until something downstream consumes it.
        [
            f"resources/entsoe/{p['bidding_zone']}_{p['start_date']}_{p['end_date']}_full.parquet"
            for p in projects["projects"].values()
            if p.get("bidding_zone")
        ],
