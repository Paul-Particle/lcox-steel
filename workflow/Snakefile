configfile: "config/config.yaml"


import sys
from pathlib import Path

sys.path.insert(0, str(Path(workflow.basedir)))

# VM workaround: strip NUL bytes that occasionally corrupt source files.
# The VM filesystem can write trailing NUL padding on flush; this scrubs them
# from Python scripts, Snakemake rules files, and the Snakefile itself so that
# git always sees clean text objects.
onstart:
    _smk_root = Path(workflow.basedir)
    _targets = list(_smk_root.glob("scripts/**/*.py")) + \
               list(_smk_root.glob("rules/**/*.smk")) + \
               [_smk_root / "Snakefile"]
    for p in _targets:
        if not p.exists():
            continue
        data = p.read_bytes()
        if b'\x00' in data:
            p.write_bytes(data.replace(b'\x00', b''))
            print(f"VM workaround: Removed NUL bytes from {p.relative_to(_smk_root)}")

import pandas as pd

projects_df = pd.read_csv(
    "config/projects.csv", dtype={"start_date": str, "end_date": str}
)

# (project, scenario, tech) is the natural row key in projects.csv; two rows
# with the same triple would silently merge in the DAG and confuse downstream
# lookup() calls, so reject the file at load time.
_key = ["project", "scenario", "tech"]
if projects_df.duplicated(subset=_key).any():
    dups = projects_df[projects_df.duplicated(subset=_key, keep=False)][_key]
    raise ValueError(f"projects.csv has duplicate (project, scenario, tech) rows:\n{dups}")

PROJECTS = projects_df["project"].unique()


include: "rules/_optional_shim.smk"
include: "rules/grid.smk"
include: "rules/res_cf.smk"
include: "rules/h2_dri.smk"
include: "rules/viz.smk"


# Default target: a small, self-contained demo that runs after a fresh clone
# with no CDS download, no EEZ/NE zips, and no API keys. It ships a pre-sliced
# Victoria (AUS) cutout backup + derived geo parquets, and exercises the
# best-site (07) and complementarity (08) RES-CF science through to an h2_dri
# solve and a viz report. Run the full set of real projects with `snakemake all`.
rule demo:
    default_target: True
    input:
        "results/report_DEMO-VIC-2025.csv",
        "results/plots/capacity_bars/DEMO-VIC-2025.png",


rule all:
    input:
        # One report per project.
        expand("results/report_{project}.csv", project=PROJECTS),
        # One scenario-comparison bar chart per project.
        expand("results/plots/capacity_bars/{project}.png", project=PROJECTS),
