configfile: "config/config.yaml"

import yaml
with open("config/projects.yaml") as _f:
    projects = yaml.safe_load(_f)


include: "rules/common.smk"
include: "rules/grid.smk"
include: "rules/res_cf.smk"
include: "rules/h2_dri.smk"


rule all:
    default_target: True
    input:
        expand(
            "results/report_{project}.csv",
            project=lookup(dpath="projects", within=projects),
        )
